generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

// ─────────────────────────────────────────────────────────────────────────────
// CONVENCIÓN DE CAMPOS DE AUDITORÍA
// ─────────────────────────────────────────────────────────────────────────────
//
//  created_at  DateTime  @default(now())   → TODOS los modelos
//                                            Cuándo se creó el registro. Nunca cambia.
//
//  updated_at  DateTime? @updatedAt        → solo solicitud, cotizacion, boleto
//                                            NULL al crear. Se rellena automáticamente
//                                            cuando Prisma hace un .update().
//                                            Solo refleja cambios de estado, NO edición
//                                            de datos (estos modelos son inmutables).
//
//  closed_at   DateTime?                   → solo solicitud, cotizacion, boleto
//                                            NULL por defecto. Se llena manualmente
//                                            cuando el ciclo de vida de la entidad
//                                            termina (soft-close, no borrado).
//
//  disabled_at DateTime?                   → solo usuario
//                                            NULL por defecto. Se llena cuando el
//                                            usuario es desactivado (soft-disable).
// ─────────────────────────────────────────────────────────────────────────────


model boleto {
  id                      Int                       @id @default(autoincrement()) @db.UnsignedInt
  cotizacion_id           Int                       @db.UnsignedInt
  reemplaza_boleto_id     Int?                      @db.UnsignedInt
  emitido_usuario_id      Int                       @db.UnsignedInt
  estado_actual_id        Int                       @db.UnsignedInt
  cobertura               String?                   @db.VarChar(20)
  valor_final             Decimal?                  @db.Decimal(14, 2)
  cotizacion              cotizacion                @relation(fields: [cotizacion_id], references: [id], onUpdate: Restrict, map: "fk_boleto_cotizacion")
  emitido_por_usuario     usuario                   @relation("boletoEmitidoPorUsuario", fields: [emitido_usuario_id], references: [id], onUpdate: Restrict, map: "fk_boleto_usuario")
  estado_boleto           estado_boleto             @relation(fields: [estado_actual_id], references: [id], onUpdate: Restrict, map: "fk_boleto_estado")
  created_at              DateTime                  @default(now()) @db.Timestamp(0)
  updated_at              DateTime?                 @updatedAt @db.Timestamp(0)   // NULL al crear; se llena automáticamente en cada .update() (solo refleja cambio de estado)
  closed_at               DateTime?                 @db.Timestamp(0)              // NULL por defecto; se llena manualmente al cerrar el ciclo de vida del boleto
  boleto                  boleto?                   @relation("boletoToboleto", fields: [reemplaza_boleto_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_boleto_reemplaza")
  other_boleto            boleto[]                  @relation("boletoToboleto")
  historial_estado_boleto historial_estado_boleto[]
  segmento_boleto         segmento_boleto[]

  @@index([estado_actual_id], map: "fk_boleto_estado")
  @@index([emitido_usuario_id], map: "idx_boleto_usuario")
  @@index([reemplaza_boleto_id], map: "fk_boleto_reemplaza")
  @@index([cotizacion_id], map: "idx_boleto_cotizacion")
}

model cotizacion {
  id                          Int                           @id @default(autoincrement()) @db.UnsignedInt
  solicitud_id                Int                           @db.UnsignedInt
  cargada_usuario_id          Int                           @db.UnsignedInt
  cotizacion_anterior_id      Int?                          @db.UnsignedInt
  estado_actual_id            Int                           @db.UnsignedInt
  cobertura                   String?                       @db.VarChar(30)
  valor_total                 Decimal                       @db.Decimal(14, 2)
  created_at                  DateTime                  @default(now()) @db.Timestamp(0)
  updated_at                  DateTime?                 @updatedAt @db.Timestamp(0)   // NULL al crear; se llena automáticamente en cada .update() (solo refleja cambio de estado)
  closed_at                   DateTime?                 @db.Timestamp(0)
  boleto                      boleto[]
  cotizacion                  cotizacion?                   @relation("cotizacionTocotizacion", fields: [cotizacion_anterior_id], references: [id], onDelete: Restrict, onUpdate: Restrict, map: "fk_cotizacion_anterior")
  other_cotizacion            cotizacion[]                  @relation("cotizacionTocotizacion")
  cargada_por_usuario         usuario                       @relation("cotizacionCargadaPorUsuario", fields: [cargada_usuario_id], references: [id], onUpdate: Restrict, map: "fk_cotizacion_usuario")
  estado_cotizacion           estado_cotizacion             @relation(fields: [estado_actual_id], references: [id], onUpdate: Restrict, map: "fk_cotizacion_estado")
  solicitud                   solicitud                     @relation(fields: [solicitud_id], references: [id], onUpdate: Restrict, map: "fk_cotizacion_solicitud")
  historial_estado_cotizacion historial_estado_cotizacion[]
  segmento_cotizacion         segmento_cotizacion[]

  @@index([cargada_usuario_id], map: "idx_cotizacion_usuario")
  @@index([cotizacion_anterior_id], map: "fk_cotizacion_anterior")
  @@index([estado_actual_id], map: "fk_cotizacion_estado")
  @@index([solicitud_id], map: "idx_cotizacion_solicitud")
}

model estado_boleto {
  id                      Int                       @id @default(autoincrement()) @db.UnsignedInt
  estado                  String                    @db.VarChar(100)
  slug                    String                    @unique(map: "slug") @db.VarChar(100)
  editable                Boolean?                  @default(true)
  created_at                  DateTime                      @default(now()) @db.Timestamp(0)
  boleto                  boleto[]
  historial_estado_boleto historial_estado_boleto[]
}

model estado_cotizacion {
  id                          Int                           @id @default(autoincrement()) @db.UnsignedInt
  estado                      String                        @db.VarChar(100)
  slug                        String                        @unique(map: "slug") @db.VarChar(100)
  editable                    Boolean?                      @default(true)
  created_at                  DateTime                      @default(now()) @db.Timestamp(0)
  cotizacion                  cotizacion[]
  historial_estado_cotizacion historial_estado_cotizacion[]
}

model estado_solicitud {
  id                         Int                          @id @default(autoincrement()) @db.UnsignedInt
  estado                     String                       @db.VarChar(100)
  slug                       String                       @unique(map: "slug") @db.VarChar(100)
  editable                   Boolean?                     @default(true)
  created_at                 DateTime                      @default(now()) @db.Timestamp(0)
  historial_estado_solicitud historial_estado_solicitud[]
  solicitud                  solicitud[]
}

model historial_estado_boleto {
  id            Int           @id @default(autoincrement()) @db.UnsignedInt
  boleto_id     Int           @db.UnsignedInt
  estado_id     Int           @db.UnsignedInt
  usuario_id    Int           @db.UnsignedInt
  observacion   String?       @db.Text
  created_at                  DateTime                      @default(now()) @db.Timestamp(0)
  boleto        boleto        @relation(fields: [boleto_id], references: [id], onUpdate: Restrict, map: "fk_hist_boleto")
  estado_boleto estado_boleto @relation(fields: [estado_id], references: [id], onUpdate: Restrict, map: "fk_hist_boleto_estado")
  usuario       usuario       @relation(fields: [usuario_id], references: [id], onUpdate: Restrict, map: "fk_hist_boleto_usuario")

  @@index([boleto_id], map: "fk_hist_boleto")
  @@index([estado_id], map: "fk_hist_boleto_estado")
  @@index([usuario_id], map: "fk_hist_boleto_usuario")
}

model historial_estado_cotizacion {
  id                Int               @id @default(autoincrement()) @db.UnsignedInt
  cotizacion_id     Int               @db.UnsignedInt
  estado_id         Int               @db.UnsignedInt
  usuario_id        Int               @db.UnsignedInt
  observacion       String?           @db.Text
  created_at        DateTime                      @default(now()) @db.Timestamp(0)
  cotizacion        cotizacion        @relation(fields: [cotizacion_id], references: [id], onUpdate: Restrict, map: "fk_hist_cotizacion")
  estado_cotizacion estado_cotizacion @relation(fields: [estado_id], references: [id], onUpdate: Restrict, map: "fk_hist_cotizacion_estado")
  usuario           usuario           @relation(fields: [usuario_id], references: [id], onUpdate: Restrict, map: "fk_hist_cotizacion_usuario")

  @@index([cotizacion_id], map: "fk_hist_cotizacion")
  @@index([estado_id], map: "fk_hist_cotizacion_estado")
  @@index([usuario_id], map: "fk_hist_cotizacion_usuario")
}

model historial_estado_solicitud {
  id               Int              @id @default(autoincrement()) @db.UnsignedInt
  solicitud_id     Int              @db.UnsignedInt
  estado_id        Int              @db.UnsignedInt
  usuario_id       Int              @db.UnsignedInt
  observacion      String?          @db.Text
  created_at       DateTime                      @default(now()) @db.Timestamp(0)
  solicitud        solicitud        @relation(fields: [solicitud_id], references: [id], onUpdate: Restrict, map: "fk_hist_solicitud")
  estado_solicitud estado_solicitud @relation(fields: [estado_id], references: [id], onUpdate: Restrict, map: "fk_hist_solicitud_estado")
  usuario          usuario          @relation(fields: [usuario_id], references: [id], onUpdate: Restrict, map: "fk_hist_solicitud_usuario")

  @@index([solicitud_id], map: "fk_hist_solicitud")
  @@index([estado_id], map: "fk_hist_solicitud_estado")
  @@index([usuario_id], map: "fk_hist_solicitud_usuario")
}

model solicitud {
  id                         Int                          @id @default(autoincrement()) @db.UnsignedInt
  radicado                   String?                      @unique(map: "radicado") @db.VarChar(100)
  usuario_id                 Int                          @db.UnsignedInt
  estado_actual_id           Int                          @db.UnsignedInt
  tipo_de_vuelo              String                       @db.VarChar(30)
  created_at                 DateTime                     @default(now()) @db.Timestamp(0)
  updated_at                 DateTime?                    @updatedAt @db.Timestamp(0)   // NULL al crear; se llena automáticamente en cada .update() (solo refleja cambio de estado)
  closed_at                  DateTime?                    @db.Timestamp(0)              // NULL por defecto; se llena manualmente al cerrar el ciclo de vida de la solicitud
  cotizacion                 cotizacion[]
  detalle_vuelo_solicitud    detalle_vuelo_solicitud[]
  historial_estado_solicitud historial_estado_solicitud[]
  estado_solicitud           estado_solicitud             @relation(fields: [estado_actual_id], references: [id], onUpdate: Restrict, map: "fk_solicitud_estado")
  usuario                    usuario                      @relation(fields: [usuario_id], references: [id], onUpdate: Restrict, map: "fk_solicitud_usuario")

  @@index([estado_actual_id], map: "fk_solicitud_estado")
  @@index([usuario_id], map: "idx_solicitud_usuario")
}

model usuario {
  id                          Int                           @id @default(autoincrement()) @db.UnsignedInt
  numero_documento            String                        @unique(map: "numero_documento") @db.VarChar(50)
  cod_empleado                String?                       @unique(map: "cod_empleado") @db.VarChar(50)
  nombre                      String                        @db.VarChar(150)
  correo                      String                        @unique(map: "correo") @db.VarChar(255)
  username                    String                        @unique(map: "username") @db.VarChar(100)
  password_hash               String                        @db.Text
  rol                         String                        @db.VarChar(30)
  created_at                 DateTime                     @default(now()) @db.Timestamp(0)
  updated_at                 DateTime?                    @updatedAt @db.Timestamp(0)   // NULL al crear; se llena automáticamente en cada .update() (solo refleja cambio de estado)
  disabled_at                DateTime?                    @db.Timestamp(0)              // NULL por defecto; se llena cuando el usuario es desactivado (soft-disable)
  estad_sticas_de_uso_demo    estad_sticas_de_uso_demo?
  historial_estado_boleto     historial_estado_boleto[]
  historial_estado_cotizacion historial_estado_cotizacion[]
  historial_estado_solicitud  historial_estado_solicitud[]
  boletos_emitidos            boleto[]                      @relation("boletoEmitidoPorUsuario")
  cotizaciones_cargadas       cotizacion[]                  @relation("cotizacionCargadaPorUsuario")
  solicitud                   solicitud[]
}

model detalle_vuelo_solicitud {
  id                    Int       @id @default(autoincrement()) @db.UnsignedInt
  solicitud_id          Int       @db.UnsignedInt
  preferencia_aerolinea String?   @db.VarChar(100)
  origen                String    @db.VarChar(100)
  destino               String    @db.VarChar(100)
  fecha_ida             DateTime  @db.Date
  fecha_vuelta          DateTime? @db.Date
  created_at            DateTime  @default(now()) @db.Timestamp(0)
  solicitud             solicitud @relation(fields: [solicitud_id], references: [id], onUpdate: Restrict, map: "fk_detalle_solicitud")

  @@index([solicitud_id], map: "fk_detalle_solicitud")
}

model segmento_cotizacion {
  id                Int                               @id @default(autoincrement()) @db.UnsignedInt
  cotizacion_id     Int                               @db.UnsignedInt
  aerolinea         String?                           @db.VarChar(100)
  tipo_segmento     segmento_cotizacion_tipo_segmento
  numero_vuelo      String                            @db.VarChar(20)
  fecha_vuelo       DateTime                          @db.DateTime(0)
  clase_tarifaria   String?                           @db.VarChar(50)
  politica_equipaje String?                           @db.Text
  created_at            DateTime  @default(now()) @db.Timestamp(0)
  cotizacion        cotizacion                        @relation(fields: [cotizacion_id], references: [id], onUpdate: Restrict, map: "fk_segmento_cotizacion")

  @@index([cotizacion_id], map: "fk_segmento_cotizacion")
}

model segmento_boleto {
  id                     Int                           @id @default(autoincrement()) @db.UnsignedInt
  boleto_id              Int                           @db.UnsignedInt
  estado_id              Int                           @db.UnsignedInt
  aerolinea              String?                       @db.VarChar(100)
  codigo_reserva         String?                       @db.VarChar(20)
  numero_tiquete         String?                       @db.VarChar(50)
  tipo_segmento          segmento_boleto_tipo_segmento
  fecha_compra           DateTime?                     @db.Date
  numero_vuelo           String                        @db.VarChar(20)
  fecha_vuelo            DateTime                      @db.DateTime(0)
  clase_tarifaria        String?                       @db.VarChar(50)
  politica_equipaje      String?                       @db.Text
  url_archivo_adjunto    String?                       @db.Text
  created_at            DateTime  @default(now()) @db.Timestamp(0)
  boleto                 boleto                        @relation(fields: [boleto_id], references: [id], onUpdate: Restrict, map: "fk_segmento_boleto")
  estado_segmento_boleto estado_segmento_boleto        @relation(fields: [estado_id], references: [id], onUpdate: Restrict, map: "fk_segmento_estado")

  @@index([boleto_id], map: "fk_segmento_boleto")
  @@index([estado_id], map: "idx_segmento_estado")
}

model estado_segmento_boleto {
  id              Int               @id @default(autoincrement()) @db.UnsignedInt
  estado          String            @db.VarChar(50)
  slug            String            @unique(map: "slug") @db.VarChar(50)
  editable        Boolean?          @default(true)
  descripcion     String?           @db.VarChar(255)
  created_at            DateTime  @default(now()) @db.Timestamp(0)
  segmento_boleto segmento_boleto[]
}

model estad_sticas_de_uso_demo {
  id                   Int      @id @default(autoincrement()) @db.UnsignedInt
  user_id              Int      @unique(map: "user_id") @db.UnsignedInt
  solicitudes_creadas  Int?     @default(0) @db.UnsignedInt
  cotizaciones_creadas Int?     @default(0) @db.UnsignedInt
  boletos_creados      Int?     @default(0) @db.UnsignedInt
  ultima_actualizacion DateTime @default(now()) @db.Timestamp(0)
  created_at            DateTime  @default(now()) @db.Timestamp(0)
  usuario              usuario  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "estadísticas_de_uso_demo_ibfk_1")

  @@map("estadísticas_de_uso_demo")
}

enum segmento_boleto_tipo_segmento {
  IDA
  VUELTA
  ESCALA
}

enum segmento_cotizacion_tipo_segmento {
  IDA
  VUELTA
  ESCALA
}
